---
import Layout from '../layouts/Layout.astro';
import ClimaSection from '../components/ClimaSection.astro';
import HabitosSection from '../components/HabitosSection.astro';
import EstadisticasSection from '../components/EstadisticasSection.astro';
---

<Layout title="Dashboard - Clima y Hábitos">
  <section class="hero">
    <div class="container">
      <div class="hero-content">
        <h1>Dashboard Personal</h1>
        <p class="hero-subtitle">
          Monitorea el clima de tu ciudad y sigue tus hábitos diarios en un solo lugar
        </p>
        <a href="#clima" class="cta-button">Comenzar</a>
      </div>
    </div>
  </section>

  <ClimaSection />
  <HabitosSection />
  <EstadisticasSection />
</Layout>

<style>
  .hero {
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-secondary) 100%);
    color: white;
    padding: calc(var(--spacing-2xl) * 2) 0;
    text-align: center;
    animation: fadeIn 0.6s ease-out;
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--spacing-xl);
  }

  .hero h1 {
    margin: 0;
    color: white;
    font-size: 3rem;
  }

  .hero-subtitle {
    font-size: 1.25rem;
    color: rgba(255, 255, 255, 0.9);
    max-width: 600px;
    margin: 0;
  }

  .cta-button {
    display: inline-block;
    background-color: white;
    color: var(--color-primary);
    padding: var(--spacing-md) var(--spacing-xl);
    border-radius: 0.5rem;
    font-weight: 600;
    transition: all 0.3s ease;
    text-decoration: none;
  }

  .cta-button:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.2);
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 768px) {
    .hero {
      padding: var(--spacing-2xl) 0;
    }

    .hero h1 {
      font-size: 2rem;
    }

    .hero-subtitle {
      font-size: 1rem;
    }
  }
</style>
