---
import BarChart from './BarChart.astro';
---

<section id="estadisticas" class="estadisticas-section section">
  <div class="container">
    <h2>📊 Estadísticas</h2>

    <div class="stats-grid">
      <div class="stat-card">
        <h3>Hábitos Completados Hoy</h3>
        <div class="stat-value" id="completed-today">0</div>
      </div>

      <div class="stat-card">
        <h3>Total de Hábitos</h3>
        <div class="stat-value" id="total-habits">0</div>
      </div>

      <div class="stat-card">
        <h3>Mejor Racha</h3>
        <div class="stat-value" id="best-streak">0</div>
      </div>

      <div class="stat-card">
        <h3>Porcentaje Completado</h3>
        <div class="stat-value" id="completion-rate">0%</div>
      </div>
    </div>

    <div class="charts-container">
      <div id="chart-container" class="chart-wrapper">
        <!-- Se renderiza con JavaScript -->
      </div>
    </div>
  </div>
</section>

<script>
  function updateStatistics() {
    const stored = localStorage.getItem('habits');
    const habits = stored ? JSON.parse(stored) : [];

    if (habits.length === 0) {
      document.getElementById('completed-today').textContent = '0';
      document.getElementById('total-habits').textContent = '0';
      document.getElementById('best-streak').textContent = '0';
      document.getElementById('completion-rate').textContent = '0%';
      return;
    }

    // Calcular estadísticas
    const completedToday = habits.filter(h => h.completed).length;
    const totalHabits = habits.length;
    const bestStreak = Math.max(...habits.map(h => h.streak), 0);
    const completionRate = Math.round((completedToday / totalHabits) * 100);

    // Actualizar valores
    document.getElementById('completed-today').textContent = completedToday;
    document.getElementById('total-habits').textContent = totalHabits;
    document.getElementById('best-streak').textContent = bestStreak;
    document.getElementById('completion-rate').textContent = `${completionRate}%`;

    // Crear datos para gráfico
    const chartData = habits.map((habit, index) => ({
      label: habit.name.substring(0, 15),
      value: habit.streak,
      color: ['#6366f1', '#ec4899', '#f59e0b', '#10b981', '#06b6d4'][index % 5]
    }));

    if (chartData.length > 0) {
      renderChart(chartData);
    }
  }

  function renderChart(data) {
    const container = document.getElementById('chart-container');
    container.innerHTML = `
      <div class="chart-content">
        <h3>Racha por Hábito</h3>
        <div class="bars">
          ${data.map((item, index) => {
            const maxValue = Math.max(...data.map(d => d.value)) || 1;
            const percentage = (item.value / maxValue) * 100;
            return `
              <div class="bar-item" key="${index}">
                <div class="bar-label">${item.label}</div>
                <div class="bar-wrapper">
                  <div class="bar-fill" style="
                    width: ${percentage}%;
                    background-color: ${item.color};
                  "></div>
                </div>
                <div class="bar-value">${item.value}</div>
              </div>
            `;
          }).join('')}
        </div>
      </div>
    `;
  }

  // Actualizar estadísticas al cargar
  updateStatistics();

  // Observer para cambios en localStorage
  window.addEventListener('storage', updateStatistics);
  
  // Actualizar cada vez que se modifiquen los hábitos
  const originalSetItem = localStorage.setItem;
  localStorage.setItem = function(...args) {
    originalSetItem.apply(this, args);
    if (args[0] === 'habits') {
      updateStatistics();
    }
  };
</script>

<style scoped>
  .section {
    padding: var(--spacing-2xl) 0;
  }

  .section h2 {
    margin-bottom: var(--spacing-xl);
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: var(--spacing-lg);
    margin-bottom: var(--spacing-2xl);
  }

  .stat-card {
    background-color: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: 1rem;
    padding: var(--spacing-lg);
    text-align: center;
    transition: all 0.3s ease;
  }

  .stat-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
    border-color: var(--color-primary);
  }

  .stat-card h3 {
    margin: 0 0 var(--spacing-md) 0;
    color: var(--text-secondary);
    font-size: 1rem;
    font-weight: 500;
  }

  .stat-value {
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--color-primary);
    background: linear-gradient(135deg, var(--color-primary), var(--color-secondary));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .charts-container {
    background-color: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: 1rem;
    padding: var(--spacing-lg);
  }

  .chart-content {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-lg);
  }

  .chart-content h3 {
    margin: 0;
  }

  .bars {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
  }

  .bar-item {
    display: flex;
    align-items: center;
    gap: var(--spacing-md);
  }

  .bar-label {
    min-width: 80px;
    font-weight: 500;
    color: var(--text-primary);
    font-size: 0.875rem;
  }

  .bar-wrapper {
    flex: 1;
    height: 2rem;
    background-color: var(--bg-tertiary);
    border-radius: 0.5rem;
    overflow: hidden;
  }

  .bar-fill {
    height: 100%;
    border-radius: 0.5rem;
    transition: width 0.5s ease;
  }

  .bar-value {
    min-width: 30px;
    text-align: right;
    font-weight: 600;
    color: var(--text-primary);
  }

  @media (max-width: 768px) {
    .section {
      padding: var(--spacing-xl) 0;
    }

    .stats-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--spacing-md);
    }

    .stat-value {
      font-size: 2rem;
    }

    .stat-card h3 {
      font-size: 0.875rem;
    }

    .charts-container {
      padding: var(--spacing-md);
    }

    .bar-item {
      gap: var(--spacing-sm);
    }

    .bar-label {
      min-width: 60px;
      font-size: 0.75rem;
    }
  }
</style>
