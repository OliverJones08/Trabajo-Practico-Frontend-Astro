---
---

<section id="clima" class="clima-section section">
  <div class="container">
    <h2>🌤️ Clima Actual</h2>
    
    <div class="clima-search">
      <input 
        type="text" 
        id="city-input" 
        placeholder="Buscar ciudad..." 
        aria-label="Buscar ciudad"
      >
      <button id="search-btn" class="btn-primary">Buscar</button>
    </div>

    <div id="clima-content" class="clima-grid">
      <!-- Cargará dinámicamente -->
    </div>

    <div id="loading" class="loading" style="display: none;">
      <p>Cargando datos...</p>
    </div>

    <div id="error" class="error-message" style="display: none;"></div>
  </div>
</section>

<script>
  const DEFAULT_CITY = 'Buenos Aires';

  const searchBtn = document.getElementById('search-btn');
  const cityInput = document.getElementById('city-input');
  const climaContent = document.getElementById('clima-content');
  const loading = document.getElementById('loading');
  const errorDiv = document.getElementById('error');

  async function getWeather(city = DEFAULT_CITY) {
    loading.style.display = 'block';
    errorDiv.style.display = 'none';
    climaContent.innerHTML = '';

    try {
      // Usar Open-Meteo API (sin API key requerida)
      const geoResponse = await fetch(
        `https://geocoding-api.open-meteo.com/v1/search?name=${encodeURIComponent(city)}&count=1&language=es&format=json`
      );

      const geoData = await geoResponse.json();

      if (!geoData.results || geoData.results.length === 0) {
        throw new Error('Ciudad no encontrada');
      }

      const location = geoData.results[0];
      const weatherResponse = await fetch(
        `https://api.open-meteo.com/v1/forecast?latitude=${location.latitude}&longitude=${location.longitude}&current=temperature_2m,weather_code,temperature_apparent_mean,relative_humidity_2m,pressure_msl,visibility&timezone=auto`
      );

      const weatherData = await weatherResponse.json();
      const data = {
        name: location.name,
        sys: { country: location.country_code },
        main: {
          temp: weatherData.current.temperature_2m,
          feels_like: weatherData.current.temperature_apparent_mean,
          humidity: weatherData.current.relative_humidity_2m,
          pressure: weatherData.current.pressure_msl
        },
        wind: { speed: 0 },
        visibility: weatherData.current.visibility,
        weather: [{ main: getWeatherType(weatherData.current.weather_code), description: getWeatherDescription(weatherData.current.weather_code) }]
      };
      
      // Mapeo de códigos WMO a iconos
      const weatherIcons = {
        'Clear': '☀️',
        'Cloudy': '☁️',
        'Rainy': '🌧️',
        'Drizzle': '🌦️',
        'Thunderstorm': '⛈️',
        'Snow': '❄️',
        'Fog': '🌫️'
      };

      const icon = weatherIcons[data.weather[0].main] || '🌤️';

      climaContent.innerHTML = `
        <div class="weather-main animate-fade-in">
          <div class="weather-header">
            <h3>${data.name}, ${data.sys.country}</h3>
            <p>${new Date().toLocaleDateString('es-AR', {
              weekday: 'long',
              year: 'numeric',
              month: 'long',
              day: 'numeric'
            })}</p>
          </div>
          <div class="weather-display">
            <div class="weather-temp">
              <span class="icon">${icon}</span>
              <span class="temp">${Math.round(data.main.temp)}°C</span>
            </div>
            <div class="weather-description">
              <p>${data.weather[0].description}</p>
              <p>Sensación térmica: ${Math.round(data.main.feels_like)}°C</p>
            </div>
          </div>
          <div class="weather-details">
            <div class="detail">
              <span>💧 Humedad</span>
              <span>${data.main.humidity}%</span>
            </div>
            <div class="detail">
              <span>🌡️ Presión</span>
              <span>${Math.round(data.main.pressure)} hPa</span>
            </div>
            <div class="detail">
              <span>👁️ Visibilidad</span>
              <span>${(data.visibility / 1000).toFixed(1)} km</span>
            </div>
            <div class="detail">
              <span>📍 Coordenadas</span>
              <span>${data.name}</span>
            </div>
          </div>
        </div>
      `;
    } catch (error) {
      errorDiv.textContent = `Error: ${error.message}. Por favor, intenta con otra ciudad.`;
      errorDiv.style.display = 'block';
    } finally {
      loading.style.display = 'none';
    }
  }

  // Función para convertir código WMO a descripción legible
  function getWeatherType(code) {
    if (code === 0 || code === 1) return 'Clear';
    if (code === 2) return 'Cloudy';
    if (code === 3) return 'Cloudy';
    if (code === 45 || code === 48) return 'Fog';
    if (code === 51 || code === 53 || code === 55) return 'Drizzle';
    if (code === 61 || code === 63 || code === 65) return 'Rainy';
    if (code === 71 || code === 73 || code === 75 || code === 77 || code === 80 || code === 81 || code === 82) return 'Snow';
    if (code === 80 || code === 81 || code === 82) return 'Rainy';
    if (code === 85 || code === 86) return 'Snow';
    if (code === 80 || code === 81 || code === 82) return 'Rainy';
    if (code >= 80 && code <= 82) return 'Rainy';
    if (code >= 85 && code <= 86) return 'Snow';
    if (code >= 90 && code <= 99) return 'Thunderstorm';
    return 'Cloudy';
  }

  function getWeatherDescription(code) {
    const descriptions = {
      0: 'Cielo despejado',
      1: 'Principalmente despejado',
      2: 'Parcialmente nublado',
      3: 'Nublado',
      45: 'Niebla',
      48: 'Niebla',
      51: 'Llovizna',
      53: 'Llovizna',
      55: 'Llovizna densa',
      61: 'Lluvia',
      63: 'Lluvia moderada',
      65: 'Lluvia fuerte',
      71: 'Nieve',
      73: 'Nieve',
      75: 'Nieve fuerte',
      77: 'Granos de nieve',
      80: 'Lluvia',
      81: 'Lluvia fuerte',
      82: 'Lluvia muy fuerte',
      85: 'Nieve',
      86: 'Nieve fuerte',
      95: 'Tormenta',
      96: 'Tormenta con granizo',
      99: 'Tormenta con granizo fuerte'
    };
    return descriptions[code] || 'Condición desconocida';
  }

  // Event listeners
  searchBtn.addEventListener('click', () => {
    const city = cityInput.value.trim();
    if (city) {
      getWeather(city);
    }
  });

  cityInput.addEventListener('keypress', (e) => {
    if (e.key === 'Enter') {
      const city = cityInput.value.trim();
      if (city) {
        getWeather(city);
      }
    }
  });

  // Cargar clima por defecto al iniciar
  getWeather();
</script>

<style scoped>
  .section {
    padding: var(--spacing-2xl) 0;
    border-bottom: 1px solid var(--border-color);
  }

  .section h2 {
    margin-bottom: var(--spacing-xl);
    font-size: 2rem;
  }

  .clima-search {
    display: flex;
    gap: var(--spacing-md);
    margin-bottom: var(--spacing-2xl);
    flex-wrap: wrap;
  }

  .clima-search input {
    flex: 1;
    min-width: 200px;
  }

  .clima-search button {
    min-width: 120px;
  }

  .clima-grid {
    display: grid;
    gap: var(--spacing-lg);
  }

  .weather-main {
    background-color: var(--bg-secondary);
    border-radius: 1rem;
    padding: var(--spacing-xl);
    border: 1px solid var(--border-color);
  }

  .weather-header h3 {
    margin: 0;
    margin-bottom: var(--spacing-xs);
  }

  .weather-header p {
    margin: 0;
    color: var(--text-tertiary);
    font-size: 0.9rem;
  }

  .weather-display {
    display: flex;
    align-items: center;
    gap: var(--spacing-xl);
    margin: var(--spacing-lg) 0;
    padding: var(--spacing-lg) 0;
    border-top: 1px solid var(--border-color);
    border-bottom: 1px solid var(--border-color);
  }

  .weather-temp {
    display: flex;
    align-items: center;
    gap: var(--spacing-md);
  }

  .icon {
    font-size: 4rem;
  }

  .temp {
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--color-primary);
  }

  .weather-description {
    flex: 1;
  }

  .weather-description p {
    margin: 0;
    font-size: 1.1rem;
    text-transform: capitalize;
  }

  .weather-details {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: var(--spacing-md);
    margin-top: var(--spacing-lg);
  }

  .detail {
    display: flex;
    flex-direction: column;
    padding: var(--spacing-md);
    background-color: var(--bg-tertiary);
    border-radius: 0.5rem;
    text-align: center;
  }

  .detail span:first-child {
    color: var(--text-secondary);
    font-size: 0.9rem;
    margin-bottom: var(--spacing-xs);
  }

  .detail span:last-child {
    font-weight: 600;
    font-size: 1.25rem;
    color: var(--color-primary);
  }

  .loading {
    text-align: center;
    padding: var(--spacing-2xl);
    color: var(--text-secondary);
  }

  .error-message {
    background-color: rgba(239, 68, 68, 0.1);
    border: 1px solid var(--color-danger);
    border-radius: 0.5rem;
    padding: var(--spacing-lg);
    color: var(--color-danger);
    text-align: center;
  }

  @media (max-width: 768px) {
    .section {
      padding: var(--spacing-xl) 0;
    }

    .climate-search {
      flex-direction: column;
    }

    .climate-search input {
      width: 100%;
    }

    .climate-search button {
      width: 100%;
    }

    .weather-display {
      flex-direction: column;
      text-align: center;
    }

    .icon {
      font-size: 3rem;
    }

    .temp {
      font-size: 2rem;
    }

    .weather-details {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
